// markdownlint-cli2 config
// rules: https://github.com/DavidAnson/markdownlint/blob/main/doc/Rules.md
// lint: `markdownlint-cli2 "**/*.md"`
// tables are formatted by prettier (see .prettierrc); this tool lints content.
{
  "config": {
    "default": true,
    // line length: exempt tables, code blocks, and headings
    "MD013": { "tables": false, "code_blocks": false, "headings": false, "line_length": 100 },
    // allow multiple top-level headings
    "MD025": false,
    // allow emphasis-as-heading
    "MD036": false,
    // first line of a file doesn't need to be an h1
    "MD041": false,
    // siblings-only duplicate headings (e.g. "Scope" under several epics) are fine
    "MD024": { "siblings_only": true },
    // inline HTML is occasionally useful
    "MD033": false,
    // code blocks without an explicit language are fine (ASCII diagrams)
    "MD040": false
  },
  "globs": ["**/*.md"],
  "ignores": [
    "node_modules/**",
    "target/**",
    "vendor/**",
    ".claude/**"
  ]
}
